# --- PageSpeed Insights API (FR-02 / FR-03) ---
# Obtain from https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# --- SMTP / Email Notification (FR-06) ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL="your email"

# --- Frontend ---
# Used by the Vite client when talking to the backend.
VITE_API_BASE_URL=http://localhost:8000
